using System;
using System.Linq;
using System.Collections.Generic;

public class Solution
{
    public static long GetMinimumTransactions(int[] assetAmounts)
    {
        int n = assetAmounts.Length;
        
        // Calculate the total sum of all assets
        // Using long to prevent overflow for large arrays
        long totalSum = 0;
        foreach (int amount in assetAmounts)
        {
            totalSum += amount;
        }

        long runningSumA = 0;
        long minDifference = long.MaxValue;

        // Iterate until n-1 because Portfolio B must be non-empty (j < n)
        for (int i = 0; i < n - 1; i++)
        {
            runningSumA += assetAmounts[i];
            long currentSumB = totalSum - runningSumA;
            
            // The transactions needed to equalize is the absolute difference
            long currentDifference = Math.Abs(runningSumA - currentSumB);

            if (currentDifference < minDifference)
            {
                minDifference = currentDifference;
            }
        }

        return minDifference;
    }

    public static void Main()
    {
        int[] assets = { 10, 2, 7, 6, 5 };
        Console.WriteLine($"Minimum Transactions: {GetMinimumTransactions(assets)}");
    }
}


